# Port overrides for local dev — copy to .env.local and uncomment to override.
# Usage: cp .env.example .env.local && export $(grep -v '^#' .env.local | xargs)
#
# Postgres 5432 is the most common collision (local PG install).
# NATS 4222 collides if you run another NATS server locally.
# MinIO 9000 collides with some proxy servers.

# POSTGRES_PORT=5432
# NATS_PORT=4222
# NATS_MON_PORT=8222
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# CLIQ_MOCK_PORT=8090

# Zoho Cliq outbound. The compose defaults below point the gateway at the local
# cliq-mock so `make cliq-up && make cliq-replay` closes the round-trip with NO
# real Zoho org. Override ALL of CLIQ_CLIENT_ID/SECRET/REFRESH_TOKEN together
# (NewAdapter panics on a partial set) plus the URLs to talk to real Zoho.
# CLIQ_OAUTH_URL is the full token endpoint; CLIQ_API_BASE_URL is host-only.
# CLIQ_BOT_NAME=dev-bot
# CLIQ_CLIENT_ID=dev-client-id
# CLIQ_CLIENT_SECRET=dev-client-secret
# CLIQ_REFRESH_TOKEN=dev-refresh-token
# CLIQ_API_BASE_URL=http://cliq-mock:8080
# CLIQ_OAUTH_URL=http://cliq-mock:8080/oauth/v2/token
